# CTA API Keys
# Apply for Train Tracker key: https://www.transitchicago.com/developers/traintrackerapply/
# Apply for Bus Tracker key: https://www.transitchicago.com/developers/bustracker/
CTA_TRAIN_KEY=your_train_tracker_api_key_here
CTA_BUS_KEY=your_bus_tracker_api_key_here

# Path to DuckDB database file (defaults to data/cta.duckdb if not set)
DB_PATH=data/cta.duckdb

# Data source for the Streamlit dashboard.
# Options: duckdb (local), parquet (local files), gcs (GCS bucket)
DATA_SOURCE=duckdb

# GCS configuration (required when DATA_SOURCE=gcs)
GCS_BUCKET=your_gcs_bucket_name
GCS_EXPORTS_PREFIX=exports
# GCS_CREDENTIALS_JSON='{...}'  # service account JSON; omit if using ADC (e.g. on GCP VM)
